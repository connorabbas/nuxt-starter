FROM node:22-bookworm-slim

USER root

RUN apt-get update && apt-get install -y \
    git \
    openssh-client \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

USER node

COPY --chown=node:node .devcontainer/.bashrc /home/node/.bashrc

RUN git config --global --add safe.directory /workspace

WORKDIR /workspace

EXPOSE 3000

CMD ["bash"]
